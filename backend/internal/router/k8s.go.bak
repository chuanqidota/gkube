func registerRbacRoutes(k8s *gin.RouterGroup) {
	// ServiceAccount
	k8s.GET("serviceaccount/list", k8sRbac.ServiceAccount.GetServiceAccountList)
	k8s.GET("serviceaccount/detail", k8sRbac.ServiceAccount.GetServiceAccountDetail)
